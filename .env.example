# GIC Environment Variables — EXAMPLE
# Copy this file to .env and fill in your real values.
# .env is gitignored. This file (.env.example) IS committed — it has no real secrets.

# Razorpay — https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_key_secret_here

# X_AI (Grok) — https://console.x.ai → API Keys
# Powers the AI Q&A chat assistant embedded in the worker dashboard.
XAI_API_KEY=your_xai_key_here

# WAQI Air Quality Index — https://aqicn.org/api/
# Free demo token works for Chennai: use 'demo' or register for a real token.
WAQI_TOKEN=demo

# Server port
PORT=3001
