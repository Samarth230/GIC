# ─── GIC Environment Variables — EXAMPLE ───
# Copy this file to .env and fill in your real values.
# .env is gitignored. This file (.env.example) IS committed — it has no real secrets.

# ── Razorpay ──────────────────────────────────────────
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
# key_id  : starts with rzp_test_ (test mode) or rzp_live_ (live mode)
# key_secret: shown only once when generated — save it immediately
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_key_secret_here

# ── Server ────────────────────────────────────────────
PORT=3001
